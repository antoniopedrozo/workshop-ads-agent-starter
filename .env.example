# Copia este arquivo pra .env e preenche com suas credenciais
# .env está no .gitignore — nunca commita

# === Google Ads API ===
# Developer token (Tools > API Center). Aprovação leva 1-3 dias.
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth client (Google Cloud Console, tipo Desktop App)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Refresh token (gerado por api/google-ads/01_auth_setup.py)
GOOGLE_ADS_REFRESH_TOKEN=

# IDs sem hífen, 10 dígitos
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# === Meta Ads API ===
META_APP_ID=
META_APP_SECRET=

# System user token (NUNCA token de usuário pessoal)
META_ACCESS_TOKEN=

# Formato: act_1234567890123456
META_AD_ACCOUNT_ID=

# === LinkedIn Ads API ===
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Token expira em 60 dias por padrão
LINKEDIN_ACCESS_TOKEN=

# Só os dígitos, sem o prefixo urn:li:sponsoredAccount:
LINKEDIN_AD_ACCOUNT_ID=

# === Defaults opcionais ===
# Moeda padrão pra logs e estimativas (não muda o que tá nas plataformas)
DEFAULT_CURRENCY=BRL

# Timezone pra reports
DEFAULT_TIMEZONE=America/Sao_Paulo
